<template>
  <view class="player-card" wx:if="{{playUrl}}">
    <view class="player-controls">
      <view class="play-btn {{isPlaying ? 'playing' : ''}}" bindtap="handleTogglePlay">
        <icon name="{{isPlaying ? 'pause' : 'play'}}" size="28" color="#3d8b7a" />
      </view>
      <view class="progress-section">
        <slider
          class="progress-slider"
          min="0"
          max="{{duration}}"
          value="{{currentTime}}"
          block-size="12"
          activeColor="#3d8b7a"
          backgroundColor="#e5e7eb"
          bindchange="onSliderChange"
          bindchanging="onSliderChanging"
        />
        <view class="time-display">
          <text class="current">{{currentTimeStr}}</text>
          <text class="total">{{durationStr}}</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    playUrl: {
      type: String,
      value: ''
    },
    file: {
      type: Object,
      value: {}
    },
    isPlaying: {
      type: Boolean,
      value: false
    },
    duration: {
      type: Number,
      value: 0
    },
    currentTime: {
      type: Number,
      value: 0
    },
    currentTimeStr: {
      type: String,
      value: '00:00'
    },
    durationStr: {
      type: String,
      value: '00:00'
    }
  },
  methods: {
    handleTogglePlay() {
      this.triggerEvent('togglePlay')
    },
    onSliderChange(e) {
      this.triggerEvent('sliderChange', e.detail)
    },
    onSliderChanging(e) {
      this.triggerEvent('sliderChanging', e.detail)
    }
  }
})
</script>

<style>
.player-card {
  background: #ffffff;
  padding: 32rpx;
  margin: 0 32rpx 32rpx;
  border-radius: 20rpx;
  position: sticky;
  /* 避开自定义导航栏 (动态计算的高度) 外加一个小空隙 (16rpx) */
  top: calc(var(--nav-height, calc(88rpx + env(safe-area-inset-top))) + 16rpx);
  z-index: 10;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.player-controls {
  display: flex;
  align-items: center;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  background: #f1f5f9;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.play-btn:active {
  transform: scale(0.95);
  background: #e2e8f0;
}

.play-btn.playing {
  background: #e0f2fe;
}

.progress-section {
  flex: 1;
  min-width: 0;
}

.progress-slider {
  margin: 0 0 10rpx 0;
}

.time-display {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #6b7280;
  padding: 0 10rpx;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {
    "icon": "../../../components/icon"
  }
}
</script>